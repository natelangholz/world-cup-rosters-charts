# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data files (keep structure, ignore content)
# Exclude main data directory but allow dashboard data
data/raw/**/*.csv
data/raw/**/*.json
data/processed/**/*.csv
data/processed/**/*.json
data/cache/**/*

# Keep directory structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/cache/.gitkeep

# Allow dashboard data files (needed for GitHub Pages deployment)
!dashboard/data/processed/*.csv

# Logs
*.log
logs/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Playwright
playwright/.auth/
test-results/
playwright-report/

# Archive directory (deprecated/test code)
archive/

# Environment variables
.env
.env.local
